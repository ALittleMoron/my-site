# Safe test-only settings. These values are intentionally non-secret.

# App
APP_URL_SCHEMA=http
APP_DEBUG=true
APP_SECRET_KEY=TEST_SECRET_KEY
APP_DOMAIN=localhost
APP_USE_CACHE=false
APP_CONTACT_REQUESTS_ENABLED=false

# I18n
I18N_DEFAULT_LANGUAGE=ru

# Competency Matrix
COMPETENCY_MATRIX_QUESTION_SUGGESTION_ANONYMOUS_DAILY_LIMIT=10

# TaskIQ
TASKIQ_AUTH_SESSION_PRUNE_INTERVAL_SECONDS=86400
TASKIQ_CACHE_WARM_INTERVAL_SECONDS=3600
TASKIQ_RESULT_EXPIRE_SECONDS=3600

# Cache warm
CACHE_WARM_ARTICLES_PAGE_SIZE=10

# Owner
OWNER_INIT_LOGIN=owner
OWNER_INIT_PASSWORD=owner

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_DRIVER=postgresql+psycopg
DB_HOST=localhost
DB_PORT=55432
DB_NAME=my_site_database_test
DB_POOL_PRE_PING=true
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_EXPIRE_ON_COMMIT=false
DB_LOG_QUERY_METRICS=false
DB_SLOW_QUERY_LOG_THRESHOLD_MS=250
DB_SLOW_QUERY_LOG_STATEMENT_MAX_LENGTH=1000

# Auth
AUTH_TOKEN_EXPIRE_SECONDS=900
AUTH_SESSION_EXPIRE_SECONDS=2592000
AUTH_SESSION_ABSOLUTE_EXPIRE_SECONDS=2592000
AUTH_TOKEN_HEADER_NAME=Authorization
AUTH_TOKEN_PREFIX=Bearer
AUTH_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMCowBQYDK2VwAyEAgiimqA4yuUL9ahhsRGooZXoO4XTDzmK+pu4mJnfdPIk=\n-----END PUBLIC KEY-----\n"
AUTH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMC4CAQAwBQYDK2VwBCIEIHvAarrKpuBdN5qcsk7uVGwHA3HuzMr0j7ZGvIruVb+B\n-----END PRIVATE KEY-----\n"

# Minio
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_REGION=us-east-1
MINIO_SECRET_KEY=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_CORS_MAX_AGE_SECONDS=300

# Sentry
SENTRY_USE=false
SENTRY_DSN=

# Cache
VALKEY_HOST=localhost
VALKEY_PORT=6379

# Performance (PERFORMANCE_REPORT_DIR is relative to backend/)
PERFORMANCE_HOST=http://127.0.0.1:8000
PERFORMANCE_REPORT_DIR=performance/reports
PERFORMANCE_LANGUAGE=ru
PERFORMANCE_INCLUDE_SPA=false
PERFORMANCE_INCLUDE_MATRIX_SUGGESTIONS=false
PERFORMANCE_VALIDATE_RESPONSES=true
PERFORMANCE_SEED_DATA=true
PERFORMANCE_USERS=4
PERFORMANCE_SPAWN_RATE=1
PERFORMANCE_RUN_TIME=1m
PERFORMANCE_BASELINE_USERS=16
PERFORMANCE_BASELINE_SPAWN_RATE=4
PERFORMANCE_BASELINE_RUN_TIME=10m
LOCUST_MAX_FAILURE_RATIO=0.0
LOCUST_MAX_AVG_RESPONSE_MS=50
LOCUST_MAX_P95_RESPONSE_MS=75
