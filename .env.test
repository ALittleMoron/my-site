# Safe test-only settings. These values are intentionally non-secret.

# App
APP_URL_SCHEMA=http
APP_DEBUG=true
APP_SECRET_KEY=TEST_SECRET_KEY
APP_DOMAIN=localhost
APP_USE_CACHE=false
APP_USE_RATE_LIMIT=true

# Admin
ADMIN_INIT_LOGIN=admin
ADMIN_INIT_PASSWORD=admin

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_DRIVER=postgresql+psycopg
DB_HOST=localhost
DB_PORT=55432
DB_NAME=my_site_database_test
DB_POOL_PRE_PING=true
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_EXPIRE_ON_COMMIT=false

# Auth
AUTH_TOKEN_EXPIRE_SECONDS=172800
AUTH_TOKEN_HEADER_NAME=Authorization
AUTH_TOKEN_PREFIX=Bearer
AUTH_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMCowBQYDK2VwAyEAgiimqA4yuUL9ahhsRGooZXoO4XTDzmK+pu4mJnfdPIk=\n-----END PUBLIC KEY-----\n"
AUTH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMC4CAQAwBQYDK2VwBCIEIHvAarrKpuBdN5qcsk7uVGwHA3HuzMr0j7ZGvIruVb+B\n-----END PRIVATE KEY-----\n"

# Minio
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_SECRET_KEY=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECURE=false
MINIO_PRESIGN_PUT_EXPIRES_SECONDS=300

# Sentry
SENTRY_USE=false
SENTRY_DSN=

# Cache
VALKEY_HOST=localhost
VALKEY_PORT=6379
