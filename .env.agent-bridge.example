# Local stdio MCP bridge. Copy to .env.agent-bridge and use absolute paths.
SITE_AGENT_API_BASE_URL=https://agent.example.test:18083/internal/agent/v1
SITE_AGENT_CA_CERTIFICATE_FILE=/absolute/path/to/web-ca-certificate.pem
SITE_AGENT_CREDENTIAL_MODE=external
SITE_AGENT_CERTIFICATE_FILE=/absolute/path/to/agent-client-certificate-chain.pem
SITE_AGENT_PRIVATE_KEY_FILE=/absolute/path/to/agent-client-private-key.pem
SITE_AGENT_REQUEST_TIMEOUT_SECONDS=10
