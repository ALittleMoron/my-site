# Docker
IMAGE_TAG=image_tag_hash
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=admin
DOCKER_PASSWORD=admin

# Nginx
LE_EMAIL=your.letsencrypt@email.com
SSL_CERT=/cert/dev.pem
SSL_KEY=/cert/dev-key.pem
VPN_BIND_ADDRESS=127.0.0.1

# Remote server
REMOTE_PATH=/my_site_application/
REMOTE_HOST=127.0.0.1
REMOTE_USER=user
SSH_PRIVATE_KEY="YOUR SSH PRIVATE KEY"

# Admin
ADMIN_INIT_LOGIN=admin
ADMIN_INIT_PASSWORD=admin

# App
APP_URL_SCHEMA=http
APP_DEBUG=true
APP_SECRET_KEY=SECRET_KEY
APP_DOMAIN=localhost
APP_USE_CACHE=true
APP_CONTACT_REQUESTS_ENABLED=false

# I18n
I18N_DEFAULT_LANGUAGE=ru

# Competency Matrix
COMPETENCY_MATRIX_QUESTION_SUGGESTION_ANONYMOUS_DAILY_LIMIT=10

# TaskIQ
TASKIQ_CACHE_WARM_INTERVAL_SECONDS=3600
TASKIQ_RESULT_EXPIRE_SECONDS=3600

# Cache warm
CACHE_WARM_NOTES_PAGE_SIZE=10

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_DRIVER=postgresql+psycopg
DB_HOST=postgres
DB_PORT=5432
DB_NAME=my_site_database
DB_POOL_PRE_PING=true
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_EXPIRE_ON_COMMIT=false
DB_LOG_QUERY_METRICS=false
DB_SLOW_QUERY_LOG_THRESHOLD_MS=250
DB_SLOW_QUERY_LOG_STATEMENT_MAX_LENGTH=1000

# Auth
AUTH_TOKEN_EXPIRE_SECONDS=172800
AUTH_TOKEN_HEADER_NAME=Authorization
AUTH_TOKEN_PREFIX=Bearer
AUTH_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n(base64 content)\n-----END PUBLIC KEY-----"
AUTH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n(base64 content)\n-----END PRIVATE KEY-----"

# Minio
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_SECRET_KEY=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECURE=false
MINIO_PRESIGN_PUT_EXPIRES_SECONDS=300

# Sentry
SENTRY_USE=true
SENTRY_DSN=https://some.sentry.io/some_id

# Cache
VALKEY_HOST=valkey
VALKEY_PORT=6379

# Performance (PERFORMANCE_REPORT_DIR is relative to backend/)
PERFORMANCE_HOST=http://localhost:8000
PERFORMANCE_REPORT_DIR=performance/reports
PERFORMANCE_LANGUAGE=ru
PERFORMANCE_INCLUDE_SPA=false
PERFORMANCE_INCLUDE_MATRIX_SUGGESTIONS=false
PERFORMANCE_VALIDATE_RESPONSES=false
PERFORMANCE_SEED_DATA=false
PERFORMANCE_USERS=4
PERFORMANCE_SPAWN_RATE=1
PERFORMANCE_RUN_TIME=1m
PERFORMANCE_BASELINE_USERS=16
PERFORMANCE_BASELINE_SPAWN_RATE=4
PERFORMANCE_BASELINE_RUN_TIME=10m
LOCUST_MAX_FAILURE_RATIO=0.0
LOCUST_MAX_AVG_RESPONSE_MS=50
LOCUST_MAX_P95_RESPONSE_MS=75
